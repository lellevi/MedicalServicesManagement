@model List<MedicalServicesManagement.WebApp.Models.AppointmentViewModel>
@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Доступные талоны:";
}

<section class="appointment section">
    <div class="container" data-aos="fade-up">
        @if (User.IsInRole(Constants.AdminRole) || User.IsInRole(Constants.ReceptionistRole))
        {
            <div class="row gy-10 mb-3">
                <div class="col-lg-10 d-flex justify-content-between align-items-center">
                    <a asp-controller="Appointments" asp-action="Add" class="btn btn-primary">Добавить талон</a>
                </div>
            </div>
        }
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="input-group">
                    <select id="specialitySelect" class="form-select" name="specialityId">
                    </select>
                    <button id="searchBySpecialityBtn" class="btn btn-outline-primary">Поиск по специальности</button>
                </div>
            </div>
        </div>

        <div id="searchResults" class="mt-3">
            <ul class="list-group">
            </ul>
        </div>

        <div class="row gy-3">

            @foreach (var appointment in Model)
            {
                <div class="col-lg-10">
                    <div class="appointment-form-wrapper appointment-card d-flex justify-content-between align-items-center">
                        <div class="appointment-info">
                            <div class="patient-name fw-bold">@appointment.Patient?.FullName</div>
                            <div class="service-name text-muted">@appointment.Service?.Name (@(appointment.Service.AgeRestriction))</div>
                            <div class="medic-name text-primary">@appointment.Medic?.FullName</div>
                            <div class="appointment-time mt-1">
                                <span class="badge bg-info">
                                    @(appointment.StartDate.ToString("dd.MM.yyyy, ddd HH:mm") + " - " + appointment.EndDate.ToString("HH:mm"))
                                </span>
                            </div>
                            <div class="appointment-status mt-1">@await Html.PartialAsync("_AppointmentStatus",appointment.Status)</div>
                            <div class="appointment-cost mt-1">
                                <span class="fw-bold text-primary">@appointment.TotalCost byn</span>
                            </div>
                        </div>

                        <div class="appointment-actions">
                            @if (User.IsInRole(Constants.AdminRole) || User.IsInRole(Constants.ReceptionistRole))
                            {
                                <a asp-action="Edit" asp-route-id="@appointment.Id" class="btn btn-sm btn-primary me-2">Редактировать</a>
                                <a asp-action="Delete" asp-route-id="@appointment.Id" class="btn btn-sm btn-danger">Удалить</a>
                            }
                            @if (User.IsInRole(Constants.PatientRole))
                            {
                                <a asp-action="Choose" asp-route-id="@appointment.Id" class="btn btn-sm btn-primary me-2">Записаться</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            $.ajax({
                url: "/MedSpecialities/GetAll",
                type: "GET",
                dataType: "json",
                success: function (data) {
                    const select = $("#specialitySelect");
                    select.empty();
                    select.append('<option value="">Выберите специальность</option>');
                    $.each(data, function (i, item) {
                        select.append(`<option value="${item.id}">${item.name}</option>`);
                    });
                },
                error: function () {
                    $("#searchResults").html("<div class='alert alert-danger'>Ошибка загрузки специальностей</div>");
                }
            });

            $("#searchBySpecialityBtn").click(function () {
                const specialityId = $("#specialitySelect").val();
                if (!specialityId) {
                    $("#searchResults").html("<div class='alert alert-warning'>Выберите специальность</div>");
                    return;
                }

                $.ajax({
                    url: "/Appointments/getAll?specialityId=" + specialityId,
                    type: "GET",
                    dataType: "json",
                    success: function (data) {
                        const searchResults = $("#searchResults");
                        searchResults.empty();

                        if (data.length == 0){
                            searchResults.html("<div class='alert alert-info'>Врачей не найдено</div>");
                        }
                        else{
                            let cardsHtml = "";
                            $.each(data, function (i, item) {
                            const fullName = `${item.surname} ${item.name} ${item.middleName || ""}`;
                            const medSpecialty = item.medSpeciality?.name || "";
                            const medInfo = item.medInfo || "";

                            cardsHtml += createCard(fullName,medSpecialty,medInfo,item.id);
                            });
                            searchResults.html(`<div class="row">${cardsHtml}</div>`);
                        }
                    },
                    error: function () {
                        $("#searchResults").html("<div class='alert alert-danger'>Ошибка поиска по специальности</div>");
                    }
                });
            });
        });

        function createCard(fullName,medSpecialty,medInfo,id){
            const url = `/Users/medic/${id}`;
            return `
                    <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
                        <div class="doctor-card card h-100 shadow-sm border-0">
                            <div class="doctor-image text-center p-4 bg-light">
                                <div class="bg-primary rounded-circle mx-auto d-flex align-items-center justify-content-center text-white" style="width: 80px; height: 80px;">
                                    <i class="fas fa-user"></i>
                                </div>
                            </div>
                            <div class="card-body">
                                <h6 class="doctor-name mb-1">${fullName}</h6>
                                <div class="doctor-specialty text-primary mb-2">${medSpecialty}</div>
                                <p class="doctor-bio text-muted mb-2 small">${medInfo}</p>
                                <div class="mt-3">
                                    <a href="${url}" class="btn-appointment btn btn-sm btn-outline-primary w-100">Предоставляемые услуги</a>
                                </div>
                            </div>
                        </div>
                    </div>`
        }
    </script>
}