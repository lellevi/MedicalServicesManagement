@model List<MedicalServicesManagement.WebApp.Models.AppointmentViewModel>
@using MedicalServicesManagement.WebApp.Enums
@using MedicalServicesManagement.WebApp.Helpers

@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Активные записи на прием";

    bool isPatient = User.IsInRole(Constants.PatientRole);
    bool isMedic = User.IsInRole(Constants.MedicRole);
}

<section class="appointment section">
    <div class="container" data-aos="fade-up">

        @if (!Model.Any())
        {
            <div class="row">
                <div class="col-12 text-center py-5">
                    <h5 class="text-muted">У вас пока нет активных записей</h5>
                </div>
            </div>
        }
        else
        {
            <div class="row gy-3">
                @foreach (var appointment in Model)
                {
                    <div class="col-lg-10" style="border: 2px solid #6c757d; border-radius: 10px; padding: 15px;">
                        <div class="appointment-form-wrapper my-appointment-card d-flex justify-content-between align-items-center">
                            <div class="appointment-info">
                                <div class="service-name fw-bold">@appointment.Service?.Name</div>
                                @if (isPatient)
                                {
                                    <div class="medic-name text-primary">@appointment.Medic?.FullName</div>
                                }
                                else if (appointment.Status != AppointmentStatus.Free)
                                {
                                    <div class="medic-name text-primary">@appointment.Patient.FullName</div>
                                }

                                <div class="appointment-time mt-2">
                                    <span class="badge bg-info fs-6 px-3 py-2">
                                        @appointment.StartDate.ToString("dd.MM.yyyy, ddd")<br />
                                        <small>@TimeFormatHelper.FormatTimeRange(appointment.StartDate, appointment.EndDate)</small>
                                    </span>
                                </div>
                                <div class="appointment-status mt-2">
                                    @await Html.PartialAsync("_AppointmentStatus", appointment.Status)
                                </div>

                                @if (isPatient)
                                {
                                    <div class="appointment-cost mt-1">
                                        <span>Начальная стоимость услуги (без учёта доп.услуг)</span>
                                        <span class="fw-bold text-success">@appointment.Service.Cost.ToString("C")</span>
                                    </div>

                                    <form asp-controller="Appointments" asp-action="Free" method="post">
                                        <input type="hidden" name="appointmentId" value="@appointment.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">Отказаться от талона</button>
                                    </form>
                                }
                                @if (isMedic)
                                {
                                    <a asp-controller="MedicalResults"
                                           asp-action="Details"
                                           asp-route-appointmentId="@appointment.Id"
                                           class="btn btn-sm btn-outline-success">
                                        Медицинский результат
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>