@model MedicalServicesManagement.WebApp.Models.TakeAppointmentViewModel
@using MedicalServicesManagement.WebApp.Enums
@using MedicalServicesManagement.WebApp.Helpers
@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Доступные талоны:";

    var appointmentsByDate = Model.AvailableAppointments
    .Where(a => a.Status == AppointmentStatus.Free)
    .GroupBy(a => a.StartDate.Date);
}

<section class="appointment section">
    <div class="container" data-aos="fade-up">
        @foreach (var dateGroup in appointmentsByDate)
        {
            <div class="row mb-4">
                <div class="col-12">
                    <h5 class="text-primary mb-3">
                        [@dateGroup.Key.ToString("d MMMM")]
                        <small class="text-muted">(@dateGroup.Key.ToString("ddd"))</small>
                    </h5>
                </div>

                @foreach (var appointment in dateGroup)
                {
                    <div class="col-lg-2 col-md-3 col-sm-4 col-6 mb-2">
                        <a asp-action="Take" asp-route-appointmentId="@appointment.Id" asp-route-patientId="@(Model.Patient?.Id ?? string.Empty)" class="btn btn-outline-primary btn-time-slot w-100 h-100 d-flex flex-column align-items-center p-3 text-decoration-none">
                            <div class="time fs-5 fw-bold mb-1">@appointment.StartDate.ToString("HH:mm")-@appointment.EndDate.ToString("HH:mm")</div>
                            <div class="duration text-muted small">
                                @TimeFormatHelper.FormatDuration(appointment.EndDate.Subtract(appointment.StartDate))
                            </div>
                        </a>
                    </div>
                }
            </div>
        }

        @if (!appointmentsByDate.Any())
        {
            <div class="row">
                <div class="col-12 text-center py-5">
                    <h5 class="text-muted">На ближайшие 3 недели нет свободных талонов</h5>
                </div>
            </div>
        }
    </div>
</section>
