@model MedicalServicesManagement.WebApp.Models.AppointmentViewModel

@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Добавление талона";
}

<section class="appointment section">
    <div class="container" data-aos="fade-up">
        <div class="row gy-4">
            <div class="col-lg-8">
                <div class="appointment-form-wrapper" data-aos="fade-up" data-aos-delay="200">
                    <form asp-action="Add" method="post" class="appointment-form php-email-form needs-validation" novalidate>
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="row gy-4">
                            <div class="col-md-12 form-group">
                                <label asp-for="MedicId">Врач</label>
                                <select asp-for="MedicId" id="dropdownMedics" class="form-control" required></select>
                                <span asp-validation-for="MedicId" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 form-group">
                                <label asp-for="ServiceId">Медицинская услуга</label>
                                <select asp-for="ServiceId" id="dropdownServices" class="form-control" required></select>
                                <span asp-validation-for="ServiceId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 form-group">
                                <label asp-for="StartDate">Дата и время начала приёма</label>
                                <input asp-for="StartDate" type="datetime-local" class="form-control" required />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 form-group">
                                <label asp-for="EndDate">Дата и время окончания приёма</label>
                                <input asp-for="EndDate" type="datetime-local" class="form-control" required />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 form-group">
                                <label asp-for="TotalCost">Стоимость услуги, byn</label>
                                <input asp-for="TotalCost" type="number" step="0.01" class="form-control" min="0" />
                                <span asp-validation-for="TotalCost" class="text-danger"></span>
                            </div>
                        </div>

                        <input type="hidden" asp-for="Id" />

                        <button type="submit" class="btn btn-appointment w-100" style="margin-top:20px">Добавить талон</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            $.ajax({
                url: "/Users/AllMedics",
                type: "GET",
                dataType: "json",
                success: function (medics) {
                    const select = $("#dropdownMedics");
                    select.empty();
                    select.append('<option value="">Выберите врача</option>');
                    $.each(medics, function (i, item) {
                        select.append(`<option value="${item.id}" data-speciality="${item.medSpecialityId}">${item.fullName}</option>`);
                    });
                },
                error: function () {
                    console.log("Ошибка загрузки врачей");
                }
            });

            $("#dropdownMedics").on("change", function () {
                const specialityId = $(this).find(":selected").data("speciality");
                const serviceSelect = $("#dropdownServices");

                serviceSelect.empty();
                serviceSelect.append('<option value="">Выберите услугу</option>');

                if (!specialityId) {
                    return;
                }

                $.ajax({
                    url: `/Services/bySpecialityId/${specialityId}`,
                    type: "GET",
                    dataType: "json",
                    success: function (services) {
                        $.each(services, function (i, item) {
                            serviceSelect.append(`<option value="${item.id}">${item.name}(${item.forAdults ? "от 18 лет" : "до 18 лет"})</option>`);
                        });
                    },
                    error: function () {
                        console.log("Ошибка загрузки услуг для выбранного врача");
                    }
                });
            });
        });
    </script>
}