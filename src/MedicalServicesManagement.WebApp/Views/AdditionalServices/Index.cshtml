@model List<MedicalServicesManagement.WebApp.Models.AdditionalServiceViewModel>

@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Дополнительные услуги";
}

<section class="appointmnet section">
    <div class="container" data-aos="fade-up">

        @if (User.IsInRole(Constants.AdminRole))
        {
            <div class="row gy-10 mb-3">
                <div class="col-lg-10 d-flex justify-content-between align-items-center">
                    <a asp-controller="AdditionalServices" asp-action="Add" class="btn btn-appointment">Добавить услугу</a>
                </div>
            </div>
        }

        <div class="row gy-3">
            @foreach (var service in Model)
            {
                <div class="col-lg-10">
                    <div class="appointment-form-wrapper additional-service-card d-flex justify-content-between align-items-center">
                        <div class="service-info">
                            <div class="service-name fw-bold">@service.Name</div>
                            <div class="service-speciality text-muted small">@service.MedSpeciality?.Name</div>
                            <div class="service-price text-primary">@service.Price.ToString("C")</div>
                        </div>
                        @if (User.IsInRole(Constants.AdminRole))
                        {
                            <div class="service-actions">
                                <a asp-action="Edit" asp-route-id="@service.Id" class="btn btn-sm btn-primary">Редактировать</a>
                                <a asp-action="Delete" asp-route-id="@service.Id" class="btn btn-sm btn-danger ms-2">Удалить</a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>