@model MedicalResultDetailsViewModel
@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Медицинский результат приёма";
}

<div class="container mt-4">
    <a class="btn btn-outline-secondary mb-3" asp-action="Index" asp-controller="MedicalResults">
        ← Назад к результатам
    </a>
    <input type="hidden" id="medicalResultMedSpecialityId" value="@Model.Service.MedSpecialityId" />
    <div class="row">
        <div class="col-md-6">
            <h5>Дополнительные услуги</h5>

            @if (Model.IsReadOnly)
            {
                <div class="alert alert-info">Редактирование закрыто: приём завершён более чем 1 час назад.</div>
            }

            @if (!Model.IsReadOnly)
            {
                <form asp-controller="AppointmentServices"
                      asp-action="Add"
                      method="post">
                    <input type="hidden" name="appointmentId" value="@Model.Appointment.Id" />

                    <div class="mb-3">
                        <label class="form-label">Дополнительная услуга (по специальности)</label>
                        <select name="additionalServiceId" class="form-select">
                            <option value="">Загрузка...</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Количество</label>
                        <input type="number" name="amount" value="1" min="1" class="form-control" />
                    </div>

@*                     <button type="submit" class="btn btn-primary" disabled="@Model.IsReadOnly">
                        Добавить услугу
                    </button> *@
                </form>
            }

            <div class="mt-3">
                <label>Уже добавленные:</label>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Услуга</th>
                            <th>Кол‑во</th>
                            <th>Сумма</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var asv in Model.AppointmentServices)
                        {
                            <tr data-service-id="@asv.AdditionalServiceId">
                                <td>@asv.AdditionalService.Name</td>
                                <td>@asv.Amount</td>
                                <td>@(asv.AdditionalService.Price* asv.Amount)</td>
                            </tr>
                        }
                        <tr>
                            <td><strong>Итого:</strong></td>
                            <td></td>
                            <td><strong>@Model.TotalCost</strong></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-6">
            <h5>Информация о приёме</h5>
            <p><strong>Пациент:</strong> @Model.Patient?.FullName</p>
            <p><strong>Врач:</strong> @Model.Medic?.FullName</p>
            <p><strong>Услуга:</strong> @Model.Service?.Name</p>
            <p><strong>Стоимость основной услуги:</strong> @Model.Service.Cost</p>
            <p><strong>Начало:</strong> @Model.Appointment.StartDate</p>
            <p><strong>Конец приёма:</strong> @Model.Appointment.EndDate</p>

            <hr />

            <form asp-action="Update" asp-route-appointmentId="@Model.Appointment.Id" method="post">
                <div class="mb-3">
                    <label class="form-label">Анамнез / данные осмотра</label>
                    <textarea asp-for="MedicalResult.ExaminationData"
                              class="form-control"
                              rows="4"
                              readonly="@Model.IsReadOnly"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Диагноз</label>
                    <input asp-for="MedicalResult.Diagnosis"
                           class="form-control"
                           readonly="@Model.IsReadOnly" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Рекомендации</label>
                    <textarea asp-for="MedicalResult.Recommendations"
                              class="form-control"
                              rows="4"
                              readonly="@Model.IsReadOnly"></textarea>
                </div>

                @if (!Model.IsReadOnly)
                {
                    <button type="submit" class="btn btn-success">Сохранить результат</button>
                }
                else
                {
                    <p class="text-muted">Редактирование закрыто: приём завершён более чем 1 час назад.</p>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const specialityId = $("#medicalResultMedSpecialityId").val();
            debugger;

            if (!specialityId) {
                return;
            }

            const select = document.querySelector("select[name='additionalServiceId']");
            if (!select) {
                return;
            }
            loadAdditionalServices(specialityId, select);
        });

        function loadAdditionalServices(specialityId, select) {
            $.ajax({
                url: "/AdditionalServices/getAll",
                type: "GET",
                dataType: "json",
                success: function (services) {
                    select.innerHTML = '<option value="">Выберите услугу</option>';
                    const filtered = services.filter(s => s.medSpecialityId === specialityId);
                    const existingIds = Array.from(
                        document.querySelectorAll("table tbody tr[data-service-id]")
                    ).map(tr => tr.getAttribute("data-service-id"));

                    filtered.forEach(function (s) {
                        const option = document.createElement("option");
                        option.value = s.id;
                        option.textContent = `${s.name} (цена: ${s.price.toFixed(2)})`;

                        if (existingIds.includes(s.id)) {
                            option.disabled = true;
                            option.style.color = "gray";
                            option.textContent += " (уже добавлена)";
                        }

                        select.appendChild(option);
                    });

                    if (filtered.length === 0) {
                        const option = document.createElement("option");
                        option.disabled = true;
                        option.textContent = "Нет доп. услуг для этой специальности";
                        select.appendChild(option);
                    }
                },
                error: function () {
                    const option = document.createElement("option");
                    option.disabled = true;
                    option.textContent = "Ошибка загрузки услуг";
                    select.innerHTML = "";
                    select.appendChild(option);
                }
            });
        }
    </script>
}