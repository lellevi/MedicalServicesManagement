@model MedicalServicesManagement.WebApp.Models.MedicalResultViewModel

@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Добавление результата обследования";
}

<section class="medical-result-create section">
    <div class="container" data-aos="fade-up">
        <a class="btn btn-outline-secondary mb-3" asp-action="Index" asp-controller="MedicalResults">
            <i class="fas fa-arrow-left"></i> Вернуться к результатам
        </a>

        <div class="row">
            <div class="col-md-12">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Диагноз</label>
                            <input asp-for="Diagnosis" class="form-control" />
                            <span asp-validation-for="Diagnosis" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Дата создания</label>
                            <input asp-for="CreatedOn" type="datetime-local" class="form-control" />
                            <span asp-validation-for="CreatedOn" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Дата изменения</label>
                            <input asp-for="ModifiedOn" type="datetime-local" class="form-control" />
                            <span asp-validation-for="ModifiedOn" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group mt-3">
                        <label class="form-label">Данные осмотра</label>
                        <textarea asp-for="ExaminationData" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="ExaminationData" class="text-danger"></span>
                    </div>

                    <div class="form-group mt-3">
                        <label class="form-label">Рекомендации</label>
                        <textarea asp-for="Recommendations" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Recommendations" class="text-danger"></span>
                    </div>

                    <div class="form-group mt-3">
                        <input type="submit" value="Сохранить результат" class="btn btn-primary" />
                        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
