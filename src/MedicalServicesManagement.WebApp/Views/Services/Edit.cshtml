@model MedicalServicesManagement.WebApp.Models.ServiceViewModel

@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Изменение услуги";
}

<section class="appointmnet section">
    <div class="container" data-aos="fade-up">
        <div class="row gy-10">
            <div class="col-lg-10">
                <div class="appointment-form-wrapper" data-aos="fade-up" data-aos-delay="200">
                    <form asp-action="Edit" method="post" class="appointment-form php-email-form needs-validation" novalidate>

                        <div class="row gy-10">
                            <div class="col-md-10 form-group">
                                <input asp-for="Name" class="form-control" placeholder="Введите название услуги" required>
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-10 form-group">
                                <label asp-for="ForAdults" class="form-check-label">Для взрослых</label>
                                <div class="form-check mt-2">
                                    <input asp-for="ForAdults" class="form-check-input" type="checkbox" id="forAdults">
                                    <label class="form-check-label" for="forAdults"></label>
                                </div>
                                <span asp-validation-for="ForAdults" class="text-danger"></span>
                            </div>

                            <div class="col-md-10 form-group">
                                <select asp-for="MedSpecialityId" id="dropdownMedSpecialities" class="form-control" required>
                                </select>
                                <span asp-validation-for="MedSpecialityId" class="text-danger"></span>
                            </div>

                            <div class="col-md-10 form-group">
                                <label asp-for="Cost">Стоимость</label>
                                <input asp-for="Cost" type="number" step="0.01" class="form-control" placeholder="0.00" required>
                                <span asp-validation-for="Cost" class="text-danger"></span>
                            </div>

                            <div class="col-md-10 form-group">
                                <textarea asp-for="Comment" rows="3" class="form-control" placeholder="Дополнительная информация"></textarea>
                                <span asp-validation-for="Comment" class="text-danger"></span>
                            </div>
                        </div>

                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-appointment w-100" style="margin-top:20px">Сохранить изменения</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function (){
            var currentSpecialityId = '@Model.MedSpecialityId';
            $.ajax({
                url: "/MedSpecialities/GetAll",
                type: "GET",
                dataType: "json",
                success: function (data) {
                    const select = $("#dropdownMedSpecialities");
                    select.empty();
                    select.append('<option value="">Выберите специальность</option>');
                    $.each(data, function (i, item) {
                        var selected = (item.id === currentSpecialityId) ? 'selected' : '';
                        select.append(`<option value="${item.id}" ${selected}>${item.name}</option>`);
                    });
                },
                error: function () {
                    console.log("Ошибка загрузки специальностей");
                }
            });
        });
    </script>
}