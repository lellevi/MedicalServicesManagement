@model List<MedicalServicesManagement.WebApp.Models.ServiceViewModel>
@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Услуги";
}

<section class="appointmnet section">
    <div class="container" data-aos="fade-up">
        @if (User.IsInRole(Constants.AdminRole))
        {
            <div class="row gy-10 mb-3">
                <div class="col-lg-10 d-flex justify-content-between align-items-center">
                    <a asp-controller="Services" asp-action="Add" class="btn btn-appointment">Добавить услугу</a>
                </div>
            </div>
        }

        <div class="row gy-3">
            @foreach (var service in Model)
            {
                <div class="col-lg-10">
                    <div class="appointment-form-wrapper med-speciality-card d-flex justify-content-between align-items-center">
                        <div class="service-info">
                            <div class="service-name fw-bold">@service.Name</div>
                            <div class="service-speciality text-muted">@service.MedSpeciality?.Name</div>
                            <div class="service-details mt-1">
                                <span class="badge @(service.ForAdults ? "bg-success" : "bg-warning") me-2">
                                    @(service.ForAdults ? "Для взрослых" : "Для детей")
                                </span>
                                <span class="fw-bold text-primary">@service.Cost ₽</span>
                            </div>
                            @if (!string.IsNullOrEmpty(service.Comment))
                            {
                                <div class="service-comment small text-secondary mt-1">@service.Comment</div>
                            }
                        </div>
                        @if (User.IsInRole(Constants.AdminRole))
                        {
                            <div class="med-speciality-actions">
                                <a asp-action="Edit" asp-route-id="@service.Id" class="btn btn-sm btn-primary">Редактировать</a>
                                <a asp-action="Delete" asp-route-id="@service.Id" class="btn btn-sm btn-danger ms-2">Удалить</a>
                            </div>
                        }
                        @if (User.IsInRole(Constants.PatientRole))
                        {
                            <div class="med-speciality-actions">
                                <a class="btn btn-sm btn-primary">Свободные талоны</a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>
