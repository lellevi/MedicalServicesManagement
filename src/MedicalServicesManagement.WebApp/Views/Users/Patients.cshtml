@model List<MedicalServicesManagement.WebApp.Models.UserViewModel>

@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Пациенты";
}

<section class="appointmnet section">
    <div class="container" data-aos="fade-up">
        <a class="btn btn-outline-secondary mb-3" asp-action="Index" asp-controller="Home"><i class="fas fa-arrow-left"></i>Вернуться</a>

        <div class="row mb-4">
            <div class="col-lg-6">
                <a asp-action="NewPatient" asp-controller="Users" class="btn btn-primary">Добавить пациента</a>
            </div>
        </div>

        <div class="row gy-3">
            @foreach (var user in Model)
            {
                <div class="col-lg-10 user-item">
                    <div class="appointment-form-wrapper user-card med-speciality-card position-relative"
                         data-user-id="@user.Id">
                        <div class="user-summary d-flex justify-content-between align-items-center">
                            <div class="user-main-info flex-grow-1">
                                <div class="service-name fw-bold">@user.FullName</div>
                                <div class="service-speciality text-muted">
                                    @(user.MedSpeciality != null ? $"Врач ({user.MedSpeciality.Name})" : "")
                                </div>
                            </div>
                            <div class="user-actions">
                                <a asp-action="Patient" asp-controller="Users" asp-route-id="@user.Id" class="btn btn-sm btn-outline-info me-2">
                                    Страница пациента
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>