@model Dictionary<string, List<MedicalServicesManagement.WebApp.Models.UserViewModel>>

@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Пользователи";
}

<section class="appointmnet section">
    <div class="container" data-aos="fade-up">
        <div class="row gy-3">
            @foreach (var roleUsers in Model)
            {
                <h2>@roleUsers.Key</h2>
                @foreach (var user in roleUsers.Value)
                {
                    <div class="col-lg-10">
                        <div class="appointment-form-wrapper user-card med-speciality-card position-relative" data-user-id="@user.Id">
                            <div class="user-summary d-flex justify-content-between align-items-center">
                                <div class="user-avatar me-3">
                                    <div class="avatar-placeholder">
                                        <i class="fas fa-user"></i>
                                    </div>
                                </div>
                                <div class="user-main-info flex-grow-1">
                                    <div class="service-name fw-bold">@user.FullName</div>
                                    <div class="service-speciality text-muted">@user.MedSpeciality?.Name</div>
                                </div>
                                <div class="user-actions">
                                    <button class="btn btn-sm btn-outline-primary toggle-user-details me-2" type="button">
                                        <i class="fas fa-chevron-down"></i>
                                    </button>
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Редактировать</a>
                                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger ms-2">Удалить</a>
                                </div>
                            </div>

                            <div class="user-details collapse mt-3 p-3 bg-light rounded" id="user-details-@user.Id">
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <strong>Дата рождения:</strong> @user.BirthDate.ToString("dd.MM.yyyy")
                                    </div>
                                    <div class="col-md-3">
                                        <strong>Телефон:</strong> @user.Telephone
                                    </div>
                                    <div class="col-md-3">
                                        <strong>Мед. информация:</strong> @user.MedInfo
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                }
            }
        </div>

    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.toggle-user-details').on('click', function() {
                var $button = $(this);
                var userId = $button.closest('.user-card').data('user-id');
                var $details = $('#user-details-' + userId);

                $details.collapse('toggle');
            });
        });
    </script>
}