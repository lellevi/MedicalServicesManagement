@model List<MedicalServicesManagement.WebApp.Models.MedSpecialityViewModel>

@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "MedSpecialities";
}

<section class="appointmnet section">
    <div class="container" data-aos="fade-up">

        <div class="row gy-10 mb-3">
            <div class="col-lg-10 d-flex justify-content-between align-items-center">
                <a asp-controller="MedSpecialities" asp-action="Add" class="btn btn-appointment">Добавить специальность</a>
            </div>
        </div>

        <div class="row gy-3">
            @foreach (var medSpeciality in Model)
            {
                <div class="col-lg-10">
                    <div class="appointment-form-wrapper med-speciality-card d-flex justify-content-between align-items-center">
                        <div class="med-speciality-name">@medSpeciality.Name</div>
                        <div class="med-speciality-actions">
                            <a asp-action="Edit" asp-route-id="@medSpeciality.Id" class="btn btn-sm btn-primary">Редактировать</a>
                            <a asp-action="Delete" asp-route-id="@medSpeciality.Id" class="btn btn-sm btn-danger ms-2">Удалить</a>
                        </div>
                    </div>
                </div>
            }
        </div>

    </div>
</section>
