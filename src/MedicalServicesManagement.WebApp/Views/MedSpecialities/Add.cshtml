@model MedicalServicesManagement.WebApp.Models.MedSpecialityViewModel

@{
    ViewData["ShowTitle"] = true;
    ViewData["Title"] = "Добавление специальности:";
}

<form asp-action="Add" method="post" class="needs-validation" novalidate>
    <input type="hidden" asp-for="Id" />
    <div>
        <div class="col-md-10 form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control">
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
    </div>
    <button type="submit" class="btn btn-appointment w-100" style="margin-top:20px">Добавить</button>
</form>